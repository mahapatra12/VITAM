# VITAM AI: Sovereign Production Environment Configuration

# --- Infrastructure ---
PORT=5101
NODE_ENV=production
FRONTEND_URL=https://vitam-ai.vercel.app
ORIGIN=https://vitam-ai.vercel.app,http://localhost:5173,http://localhost:5174
RP_ID=vitam-ai.vercel.app,localhost,127.0.0.1
CORS_ORIGINS=https://vitam-ai.vercel.app,http://localhost:5173,http://localhost:5174
VITE_API_URL=https://vitam-ai.vercel.app/api
FACE_AUTH_THRESHOLD=0.86

# --- Database (Sovereign Persistence) ---
# Replace with your Atlas connection string for persistent data
MONGO_URI=mongodb+srv://admin:pass@cluster0.mongodb.net/vitam_sovereign?retryWrites=true&w=majority
# Optional SRV fallback when local DNS blocks querySrv:
MONGO_DIRECT_URI=
MONGO_PREFER_DIRECT=false
ALLOW_IN_MEMORY_FALLBACK=false
SEED_ON_EMPTY=false
ALLOW_PROD_SEED=false
BOOTSTRAP_ADMIN_NAME=System Admin
BOOTSTRAP_ADMIN_EMAIL=admin@vitam.edu
BOOTSTRAP_ADMIN_PASSWORD=change-this-to-strong-password

# --- Security ---
JWT_SECRET=neural-sovereign-sector-9
SESSION_SECRET=instituional-synapse-pulse
ENCRYPTION_KEY=32-character-sovereign-key-here

# --- Subsystems ---
GROQ_API_KEY=your-groq-key-here
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Flags ---
MAINTENANCE_MODE=false
FREE_MODE=false
ALLOW_FREE_MODE_HEADER=false
FREE_MODE_HEADER_TOKEN=
VITE_FREE_MODE=false
VITE_FREE_MODE_TOKEN=
GLOBAL_AI_ORCHESTRATION=true
GRID_STABILITY_AUTO_RESYNC=true
RATE_LIMIT_DISABLED=false
SKIP_DB_PREFLIGHT=false
TENANT_CACHE_TTL_MS=60000
TENANT_CACHE_MAX=500
